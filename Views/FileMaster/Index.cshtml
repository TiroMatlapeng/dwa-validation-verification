@model IEnumerable<FileMaster>

@{
    ViewData["Title"] = "V&V Cases";
    bool canEdit = !User.IsInRole("ReadOnly");
    bool canCreate = User.IsInRole("Validator") || User.IsInRole("RegionalManager")
                  || User.IsInRole("NationalManager") || User.IsInRole("SystemAdmin");
}

<div class="flex-between mb-16">
    <div>
        <div class="page-title">V&amp;V Cases</div>
        <div class="page-subtitle">@Model.Count() cases found</div>
    </div>
    <div style="display:flex; gap:8px;">
        @if (canCreate)
        {
            <a asp-controller="FileMaster" asp-action="Create" class="btn btn-primary">+ New Case</a>
        }
    </div>
</div>

<!-- Filter Bar -->
<form method="get" class="filter-bar">
    <select name="status" class="form-select" style="width:auto; min-width:200px; padding:6px 10px; font-size:12px; border:1px solid #d0d5db; border-radius:4px;">
        <option value="">All Statuses</option>
        @{
            var statuses = new[] { "Not Commenced", "In Process", "Completed", "Compl require client interaction", "Compl Not Client Interaction", "Compl Post Interact Processing" };
            foreach (var s in statuses)
            {
                if ((string?)ViewBag.FilterStatus == s)
                {
                    <option value="@s" selected>@s</option>
                }
                else
                {
                    <option value="@s">@s</option>
                }
            }
        }
    </select>
    <input type="text" name="search" value="@ViewBag.FilterSearch" class="form-input" style="width:250px; padding:6px 10px; font-size:12px; border:1px solid #d0d5db; border-radius:4px;" placeholder="Search by Reg No, Farm Name, SG Code..." />
    <button type="submit" class="btn btn-primary btn-sm">Filter</button>
    <a asp-action="Index" class="btn btn-outline btn-sm">Clear</a>
</form>

<!-- Data Table -->
<div class="data-table-wrap">
    <table>
        <thead>
            <tr>
                <th>Registration Number</th>
                <th>Farm Name</th>
                <th>SG Code</th>
                <th>Catchment</th>
                <th>Status</th>
                <th>Track</th>
                <th>Property</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.RegistrationNumber</td>
                    <td>@item.FarmName</td>
                    <td class="sg-code">@item.SurveyorGeneralCode</td>
                    <td>@item.QuaternaryCatchment</td>
                    <td>
                        @{
                            var badgeClass = item.ValidationStatusName switch
                            {
                                "Completed" => "badge-green",
                                "In Process" => "badge-blue",
                                _ => "badge-grey"
                            };
                        }
                        <span class="badge @badgeClass">@(item.ValidationStatusName ?? "Not Commenced")</span>
                    </td>
                    <td>
                        @{
                            var trackLabel = item.AssessmentTrack switch
                            {
                                "S35_Verification"   => "S35 Verification",
                                "S33_2_Declaration"  => "S33(2) Declaration",
                                "S33_3_Declaration"  => "S33(3) Declaration",
                                _                    => "Standard"
                            };
                        }
                        <span class="badge badge-grey">@trackLabel</span>
                    </td>
                    <td>
                        @if (item.Property != null)
                        {
                            <a asp-controller="Property" asp-action="Details" asp-route-id="@item.PropertyId">@item.Property.PropertyReferenceNumber</a>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.FileMasterId" class="btn btn-sm btn-outline">Details</a>
                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@item.FileMasterId" class="btn btn-sm btn-outline">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.FileMasterId" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="table-pagination">
        <span>Showing @Model.Count() cases</span>
    </div>
</div>
