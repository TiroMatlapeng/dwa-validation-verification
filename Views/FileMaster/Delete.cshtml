@model FileMaster

@{
    ViewData["Title"] = "Delete V&V Case";
    bool canDelete = ViewBag.CanDelete == true;
    int letterCount        = ViewBag.BlockingLetters       ?? 0;
    int authorisationCount = ViewBag.BlockingAuthorisations ?? 0;
    int workflowCount      = ViewBag.BlockingWorkflow       ?? 0;
}

<a asp-controller="FileMaster" asp-action="Index" class="btn-back">&larr; Back to V&amp;V Cases</a>

<div class="page-title">Delete V&amp;V Case</div>
<div class="page-subtitle">Are you sure you want to delete this case?</div>

<div class="card" style="max-width: 600px;">
    <div style="margin-bottom: 16px;">
        <div class="form-label">Registration Number</div>
        <div style="font-size: 16px; font-weight: 600;">@Model.RegistrationNumber</div>
    </div>
    <div style="margin-bottom: 16px;">
        <div class="form-label">Farm Name</div>
        <div>@Model.FarmName</div>
    </div>
    <div style="margin-bottom: 16px;">
        <div class="form-label">Surveyor General Code</div>
        <div>@Model.SurveyorGeneralCode</div>
    </div>

    @if (!canDelete)
    {
        <div style="margin-top: 16px; padding: 12px 16px; background-color: #fffbeb; border: 1px solid #fcd34d; border-radius: 6px; color: #92400e; font-size: 14px;">
            <strong>Cannot delete this case.</strong> The following linked records must be removed first:
            <ul style="margin: 6px 0 0 16px; padding: 0;">
                @if (letterCount > 0)
                {
                    <li>@letterCount letter(s) issued</li>
                }
                @if (authorisationCount > 0)
                {
                    <li>@authorisationCount authorisation record(s)</li>
                }
                @if (workflowCount > 0)
                {
                    <li>@workflowCount workflow instance(s)</li>
                }
            </ul>
        </div>
    }
    else
    {
        <div style="margin-top: 20px; padding: 12px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 4px; color: #991b1b; font-size: 13px;">
            This action cannot be undone. All data associated with this V&amp;V case will be permanently removed.
        </div>
    }

    <form asp-action="Delete" asp-route-id="@Model.FileMasterId" method="post" style="margin-top: 20px;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="FileMasterId" />
        <input type="submit" value="Delete Case" class="btn btn-danger" @(!canDelete ? "disabled" : "") />
        <a asp-action="Index" class="btn btn-outline" style="margin-left: 8px;">Cancel</a>
    </form>
</div>
