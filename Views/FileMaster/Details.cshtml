@model FileMasterDetailsViewModel

@{
    ViewData["Title"] = "Case Details";
    var fm = Model.FileMaster;
    var badgeClass = fm.ValidationStatusName switch
    {
        "Completed" => "badge-green",
        "In Process" => "badge-blue",
        _ => "badge-grey"
    };
}

<a asp-controller="FileMaster" asp-action="Index" class="btn-back">&larr; Back to V&amp;V Cases</a>

<div class="detail-header">
    <div>
        <div class="page-title">@fm.RegistrationNumber</div>
        <div class="page-subtitle">@fm.FarmName · Case @fm.CaseNumber</div>
    </div>
    <div>
        <span class="badge @badgeClass">@(fm.ValidationStatusName ?? "Not Commenced")</span>
    </div>
</div>

@* Error / success banners are rendered in _Layout.cshtml via TempData["Error"] / TempData["Success"]. *@

@await Html.PartialAsync("_WorkflowPanel", Model)

@if (Model.IsReadyForLetters)
{
    @await Html.PartialAsync("_LettersPanel", Model)
}
@await Html.PartialAsync("_PortalInboxPanel", Model.FileMaster)

<div class="card" style="max-width: 900px; margin-top: 20px;">
    <div class="form-section-title">Case Information</div>
    <div class="form-row">
        <div class="form-group">
            <div class="kv"><div class="form-label">Surveyor General Code</div><div>@fm.SurveyorGeneralCode</div></div>
            <div class="kv"><div class="form-label">Primary Catchment</div><div>@fm.PrimaryCatchment</div></div>
            <div class="kv"><div class="form-label">Quaternary Catchment</div><div>@fm.QuaternaryCatchment</div></div>
            <div class="kv"><div class="form-label">Assessment Track</div><div>@(fm.AssessmentTrack ?? "--")</div></div>
            <div class="kv"><div class="form-label">Farm Number</div><div>@fm.FarmNumber</div></div>
            <div class="kv"><div class="form-label">Registration Division</div><div>@fm.RegistrationDivision</div></div>
            <div class="kv"><div class="form-label">Farm Portion</div><div>@fm.FarmPortion</div></div>
        </div>
        <div class="form-group">
            <div class="kv"><div class="form-label">Property</div><div>@(fm.Property?.PropertyReferenceNumber ?? "--")</div></div>
            <div class="kv"><div class="form-label">Organisational Unit</div><div>@(fm.OrgUnit?.Name ?? "--")</div></div>
            <div class="kv"><div class="form-label">Catchment Area</div><div>@(fm.CatchmentArea?.CatchmentCode ?? "--")</div></div>
            <div class="kv"><div class="form-label">File Created</div><div>@fm.FileCreatedDate.ToString("dd MMM yyyy")</div></div>
        </div>
    </div>

    <div style="margin-top: 20px; display: flex; gap: 8px;">
        <a asp-action="Edit" asp-route-id="@fm.FileMasterId" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@fm.FileMasterId" class="btn btn-danger">Delete</a>
    </div>
</div>

@if (fm.AssessmentTrack == "S33_2_Declaration")
{
    <div class="card" style="max-width: 900px; margin-top: 12px; border-left: 4px solid var(--dws-primary);">
        <div class="form-section-title">S33(2) Kader Asmal Declaration Data</div>
        <div class="form-row">
            <div class="form-group">
                <div class="kv"><div class="form-label">Irrigation Board</div><div>@(fm.S33_2_IrrigationBoard?.IrrigationBoardName ?? "--")</div></div>
                <div class="kv"><div class="form-label">Scheduled Area</div><div>@(fm.S33_2_ScheduledAreaName ?? "--")</div></div>
                <div class="kv">
                    <div class="form-label">Rates paid to 30 Sep 1998</div>
                    <div style="color:@(fm.S33_2_RatesPaidConfirmed ? "var(--dws-success)" : "var(--dws-danger)"); font-weight:600;">
                        @(fm.S33_2_RatesPaidConfirmed ? "Confirmed" : "Not yet confirmed")
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card" style="max-width: 900px; margin-top: 20px;">
    <div class="form-section-title">Data Capture</div>
    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px;">
        <a asp-controller="FieldAndCrop" asp-action="Index" asp-route-propertyId="@fm.PropertyId" class="btn btn-primary">
            Field &amp; Crop Records
        </a>
        <a asp-controller="Forestation" asp-action="Index" asp-route-propertyId="@fm.PropertyId" class="btn btn-primary">
            Forestation / SFRA
        </a>
        <a asp-controller="DamCalculation" asp-action="Index" asp-route-propertyId="@fm.PropertyId" class="btn btn-primary">
            Dam Calculations
        </a>
    </div>
</div>

<div class="dws-panel" style="max-width: 900px; margin-top: 20px;">
    <h2 style="margin-top: 0; font-size: var(--dws-fs-xl); color: var(--dws-primary);">Audit Trail</h2>
    @if (!Model.AuditTrail.Any())
    {
        <p style="color: var(--dws-text-muted);">No audit entries yet.</p>
    }
    else
    {
        <table class="dws-table">
            <thead>
                <tr>
                    <th>When (UTC)</th>
                    <th>Actor</th>
                    <th>Action</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.AuditTrail)
                {
                    <tr>
                        <td>@a.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(a.UserName ?? "system")</td>
                        <td>@a.Action</td>
                        <td>@(ExtractValue(a.OldValues))</td>
                        <td>@(ExtractValue(a.NewValues))</td>
                        <td>@(a.Description ?? "")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* ── ELU Lawfulness Assessment (CP7) ────────────────────────────────── *@
<div style="margin-top: 24px;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
        <h5 style="margin:0;">ELU Lawfulness Assessment</h5>
        <form asp-action="AssessLawfulness" asp-route-id="@Model.FileMaster.FileMasterId" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-primary">
                @(Model.LawfulnessAssessmentResult is null ? "Run ELU Assessment" : "Re-Assess ELU")
            </button>
        </form>
    </div>

    @if (Model.LawfulnessAssessmentResult is null)
    {
        <div style="padding:12px 16px; background:var(--dws-neutral-100); border:1px solid var(--dws-border); border-radius:6px; color:var(--dws-text-muted); font-size:13px;">
            ELU assessment has not been run for this case yet. Run it to determine lawful and unlawful water use volumes (CP7).
        </div>
    }
    else
    {
        var r = Model.LawfulnessAssessmentResult;
        <div style="font-size:12px; color:var(--dws-text-muted); margin-bottom:8px;">
            Legal framework: <strong>@r.LegalFramework</strong>
            @if (r.Gwca is not null) { <span> — @r.Gwca.GovernmentWaterControlAreaName</span> }
            &nbsp;|&nbsp; Assessed: @r.AssessedAt.ToString("dd MMM yyyy HH:mm") UTC
        </div>
        <table style="width:100%; font-size:13px; border-collapse:collapse;">
            <thead>
                <tr style="background:var(--dws-neutral-100); text-align:left;">
                    <th style="padding:6px 10px;">Category</th>
                    <th style="padding:6px 10px; text-align:right;">Total</th>
                    <th style="padding:6px 10px; text-align:right; color:var(--dws-success);">Lawful (m³)</th>
                    <th style="padding:6px 10px; text-align:right; color:var(--dws-danger);">Unlawful (m³)</th>
                    <th style="padding:6px 10px;">Limit applied</th>
                </tr>
            </thead>
            <tbody>
                <tr style="border-top:1px solid var(--dws-border);">
                    <td style="padding:6px 10px;">Irrigation</td>
                    <td style="padding:6px 10px; text-align:right;">@r.TotalIrrigationDemandM3.ToString("N0")</td>
                    <td style="padding:6px 10px; text-align:right; color:var(--dws-success); font-weight:600;">@r.LawfulIrrigationM3.ToString("N0")</td>
                    <td style="padding:6px 10px; text-align:right; color:@(r.UnlawfulIrrigationM3 > 0 ? "var(--dws-danger)" : "var(--dws-text-muted)"); font-weight:@(r.UnlawfulIrrigationM3 > 0 ? "600" : "400");">@r.UnlawfulIrrigationM3.ToString("N0")</td>
                    <td style="padding:6px 10px; font-size:11px; color:var(--dws-text-muted);">@r.IrrigationLimitApplied</td>
                </tr>
                <tr style="border-top:1px solid var(--dws-border);">
                    <td style="padding:6px 10px;">Storage (dams)</td>
                    <td style="padding:6px 10px; text-align:right;">@r.TotalDamCapacityM3.ToString("N0")</td>
                    <td style="padding:6px 10px; text-align:right; color:var(--dws-success); font-weight:600;">@r.LawfulStorageM3.ToString("N0")</td>
                    <td style="padding:6px 10px; text-align:right; color:@(r.UnlawfulStorageM3 > 0 ? "var(--dws-danger)" : "var(--dws-text-muted)"); font-weight:@(r.UnlawfulStorageM3 > 0 ? "600" : "400");">@r.UnlawfulStorageM3.ToString("N0")</td>
                    <td style="padding:6px 10px; font-size:11px; color:var(--dws-text-muted);">@r.StorageLimitApplied</td>
                </tr>
            </tbody>
        </table>
        <div style="font-size:11px; color:var(--dws-text-muted); margin-top:6px;">
            Irrigated area: @r.TotalIrrigatedAreaHa.ToString("N1") ha
        </div>
    }
</div>

@functions {
    static string ExtractValue(string? json)
    {
        if (string.IsNullOrEmpty(json)) return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return doc.RootElement.TryGetProperty("value", out var v) ? (v.GetString() ?? "") : json;
        }
        catch { return json; }
    }
}
