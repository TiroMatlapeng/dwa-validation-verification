@model FileMaster

@{
    ViewData["Title"] = "Case Details";
    var badgeClass = Model.ValidationStatusName switch
    {
        "Completed" => "badge-green",
        "In Process" => "badge-blue",
        _ => "badge-grey"
    };
}

<a asp-controller="FileMaster" asp-action="Index" class="btn-back">&larr; Back to V&amp;V Cases</a>

<!-- Detail Header -->
<div class="detail-header">
    <div>
        <div class="page-title">@Model.RegistrationNumber</div>
        <div class="page-subtitle">@Model.FarmName</div>
    </div>
    <div>
        <span class="badge @badgeClass">@(Model.ValidationStatusName ?? "Not Commenced")</span>
    </div>
</div>

<!-- Detail Card -->
<div class="card" style="max-width: 900px;">
    <div class="form-row">
        <!-- Left Column -->
        <div class="form-group">
            <div style="margin-bottom: 16px;">
                <div class="form-label">Surveyor General Code</div>
                <div>@Model.SurveyorGeneralCode</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Primary Catchment</div>
                <div>@Model.PrimaryCatchment</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Quaternary Catchment</div>
                <div>@Model.QuaternaryCatchment</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Catchment Area</div>
                <div>@(Model.CatchmentArea?.CatchmentCode ?? "--")</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Assessment Track</div>
                <div>@(Model.AssessmentTrack ?? "--")</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Farm Number</div>
                <div>@Model.FarmNumber</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Registration Division</div>
                <div>@Model.RegistrationDivision</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Farm Portion</div>
                <div>@Model.FarmPortion</div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="form-group">
            <div style="margin-bottom: 16px;">
                <div class="form-label">Property</div>
                <div>
                    @if (Model.Property != null)
                    {
                        <a asp-controller="Property" asp-action="Details" asp-route-id="@Model.PropertyId">@Model.Property.PropertyReferenceNumber</a>
                    }
                    else
                    {
                        <span>--</span>
                    }
                </div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Organisational Unit</div>
                <div>@(Model.OrgUnit?.Name ?? "--")</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Validator</div>
                <div>@(Model.Validator?.UserName ?? "--")</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">Capture Person</div>
                <div>@(Model.CapturePerson?.UserName ?? "--")</div>
            </div>
            <div style="margin-bottom: 16px;">
                <div class="form-label">File Created Date</div>
                <div>@Model.FileCreatedDate.ToString("dd MMM yyyy")</div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="form-section-title" style="margin-top: 20px;">Notes</div>
        <div style="padding: 12px; background: #f8f9fa; border-radius: 4px; font-size: 14px; line-height: 1.6;">
            @Model.Notes
        </div>
    }

    <div style="margin-top: 20px; display: flex; gap: 8px;">
        <a asp-action="Edit" asp-route-id="@Model.FileMasterId" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.FileMasterId" class="btn btn-danger">Delete</a>
    </div>
</div>
