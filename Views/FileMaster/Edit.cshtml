@model FileMaster

@{
    ViewData["Title"] = "Edit V&V Case";
}

<a asp-controller="FileMaster" asp-action="Index" class="btn-back">&larr; Back to V&amp;V Cases</a>

<div class="page-title">Edit V&amp;V Case</div>
<div class="page-subtitle">Update case file: @Model.RegistrationNumber</div>

<div class="card" style="max-width: 800px;">
    <form asp-action="Edit" asp-route-id="@Model.FileMasterId">
        <input type="hidden" asp-for="FileMasterId" />
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>

        <!-- Registration Details -->
        <div class="form-section-title">Registration Details</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="RegistrationNumber" class="form-label"></label>
                <input asp-for="RegistrationNumber" class="form-control" style="width:100%;" />
                <span asp-validation-for="RegistrationNumber" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="SurveyorGeneralCode" class="form-label"></label>
                <input asp-for="SurveyorGeneralCode" class="form-control" style="width:100%;" />
                <span asp-validation-for="SurveyorGeneralCode" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="PrimaryCatchment" class="form-label"></label>
                <input asp-for="PrimaryCatchment" class="form-control" style="width:100%;" />
                <span asp-validation-for="PrimaryCatchment" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="QuaternaryCatchment" class="form-label"></label>
                <input asp-for="QuaternaryCatchment" class="form-control" style="width:100%;" />
                <span asp-validation-for="QuaternaryCatchment" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="CatchmentAreaId" class="form-label">Catchment Area</label>
                <select asp-for="CatchmentAreaId" asp-items="@ViewBag.CatchmentAreas" class="form-control" style="width:100%;">
                    <option value="">-- Select Catchment Area --</option>
                </select>
                <span asp-validation-for="CatchmentAreaId" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="AssessmentTrack" class="form-label">Assessment Track</label>
                <select asp-for="AssessmentTrack" asp-items="@ViewBag.AssessmentTracks" class="form-control" style="width:100%;">
                    <option value="">-- Select Assessment Track --</option>
                </select>
                <span asp-validation-for="AssessmentTrack" class="text-danger text-sm"></span>
            </div>
        </div>

        @if (Model?.AssessmentTrack == "S33_2_Declaration")
        {
            <div class="form-section-title" style="margin-top: 20px;">S33(2) Kader Asmal Declaration</div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="S33_2_ScheduledAreaName" class="form-label">Scheduled Area Name</label>
                    <input asp-for="S33_2_ScheduledAreaName" class="form-control" style="width:100%;" placeholder="e.g. Upper Blyde Irrigation Scheme" />
                </div>
                <div class="form-group">
                    <label asp-for="S33_2_IrrigationBoardId" class="form-label">Irrigation Board</label>
                    <select asp-for="S33_2_IrrigationBoardId" asp-items="@(ViewBag.IrrigationBoards as SelectList)" class="form-control" style="width:100%;">
                        <option value="">-- Select irrigation board --</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="display:flex; align-items:center; gap:8px;">
                    <input asp-for="S33_2_RatesPaidConfirmed" type="checkbox" class="form-check-input" id="S33_2_RatesPaid" />
                    <label for="S33_2_RatesPaid" class="form-label" style="margin:0;">
                        Prescribed rates were paid up to <strong>30 September 1998</strong>
                    </label>
                </div>
            </div>
        }

        <!-- Farm Details -->
        <div class="form-section-title" style="margin-top: 20px;">Farm Details</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="FarmName" class="form-label"></label>
                <input asp-for="FarmName" class="form-control" style="width:100%;" />
                <span asp-validation-for="FarmName" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="FarmNumber" class="form-label"></label>
                <input asp-for="FarmNumber" class="form-control" style="width:100%;" />
                <span asp-validation-for="FarmNumber" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="RegistrationDivision" class="form-label"></label>
                <input asp-for="RegistrationDivision" class="form-control" style="width:100%;" />
                <span asp-validation-for="RegistrationDivision" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="FarmPortion" class="form-label"></label>
                <input asp-for="FarmPortion" class="form-control" style="width:100%;" />
                <span asp-validation-for="FarmPortion" class="text-danger text-sm"></span>
            </div>
        </div>

        <!-- Assignment -->
        <div class="form-section-title" style="margin-top: 20px;">Assignment</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="PropertyId" class="form-label">Property</label>
                <select asp-for="PropertyId" asp-items="@ViewBag.Properties" class="form-control" style="width:100%;">
                    <option value="">-- Select Property --</option>
                </select>
                <span asp-validation-for="PropertyId" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="OrgUnitId" class="form-label">Organisational Unit</label>
                <select asp-for="OrgUnitId" asp-items="@ViewBag.OrgUnits" class="form-control" style="width:100%;">
                    <option value="">-- Select Org Unit --</option>
                </select>
                <span asp-validation-for="OrgUnitId" class="text-danger text-sm"></span>
            </div>
        </div>

        <div style="margin-top: 20px;">
            <input type="submit" value="Save Changes" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-outline" style="margin-left: 8px;">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
