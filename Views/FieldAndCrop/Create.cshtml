@model FieldAndCropViewModel

@{
    ViewData["Title"] = "Add Field & Crop Record";
    var propertyRef = ViewBag.PropertyRef as string ?? "Property";
}

<a asp-action="Index" asp-route-propertyId="@Model.PropertyId" class="btn-back">&larr; Back to Field &amp; Crop Records</a>

<div class="page-title">Add Field &amp; Crop Record</div>
<div class="page-subtitle">Property: @propertyRef</div>

<div class="card" style="max-width: 800px;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 14px;"></div>

        <input asp-for="PropertyId" type="hidden" />

        <div class="form-section-title">Field Details</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="FieldNumber" class="form-label"></label>
                <input asp-for="FieldNumber" class="form-control" style="width:100%;" placeholder="e.g. F01" />
                <span asp-validation-for="FieldNumber" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="FieldArea" class="form-label"></label>
                <input asp-for="FieldArea" class="form-control" type="number" step="0.01" min="0" style="width:100%;" />
                <span asp-validation-for="FieldArea" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="PeriodId" class="form-label">Period</label>
                <select asp-for="PeriodId" asp-items="@ViewBag.Periods" class="form-control" style="width:100%;">
                    <option value="">-- Select Period --</option>
                </select>
                <span asp-validation-for="PeriodId" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="PlantDate" class="form-label"></label>
                <input asp-for="PlantDate" class="form-control" type="date" style="width:100%;" />
                <span asp-validation-for="PlantDate" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-section-title" style="margin-top: 16px;">Crop &amp; Water Details</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="CropId" class="form-label">Crop</label>
                <select asp-for="CropId" asp-items="@ViewBag.Crops" class="form-control" style="width:100%;">
                    <option value="">-- Select Crop --</option>
                </select>
                <span asp-validation-for="CropId" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="CropArea" class="form-label"></label>
                <input asp-for="CropArea" class="form-control" type="number" step="0.01" min="0" style="width:100%;" />
                <span asp-validation-for="CropArea" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="WaterSourceId" class="form-label">Water Source</label>
                <select asp-for="WaterSourceId" asp-items="@ViewBag.WaterSources" class="form-control" style="width:100%;">
                    <option value="">-- Select Water Source --</option>
                </select>
                <span asp-validation-for="WaterSourceId" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="IrrigationSystemId" class="form-label">Irrigation System</label>
                <select asp-for="IrrigationSystemId" asp-items="@ViewBag.IrrigationSystems" class="form-control" style="width:100%;">
                    <option value="">-- None --</option>
                </select>
                <span asp-validation-for="IrrigationSystemId" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="RotationFactor" class="form-label"></label>
                <input asp-for="RotationFactor" class="form-control" type="number" step="0.01" min="0" max="1" style="width:100%;" />
                <span asp-validation-for="RotationFactor" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="SAPWATCalculationResult" class="form-label"></label>
                <input asp-for="SAPWATCalculationResult" class="form-control" type="number" step="0.01" min="0" style="width:100%;" />
                <span asp-validation-for="SAPWATCalculationResult" class="text-danger text-sm"></span>
            </div>
        </div>

        <div style="margin-top: 20px; display: flex; gap: 8px;">
            <button type="submit" class="btn btn-primary">Save Record</button>
            <a asp-action="Index" asp-route-propertyId="@Model.PropertyId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
