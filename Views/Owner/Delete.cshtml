@model PropertyOwner

@{
    ViewData["Title"] = "Delete Owner";
    bool canDelete = ViewBag.CanDelete == true;
    int ownershipCount = ViewBag.OwnershipCount ?? 0;
}

<a asp-controller="Owner" asp-action="Index" class="btn-back">&larr; Back to Property Owners</a>

<div class="page-title">Delete Property Owner</div>
<div class="page-subtitle">Confirm permanent deletion of this owner record</div>

@if (TempData["Error"] != null)
{
    <div style="margin-bottom:14px; padding:10px 14px; background:#fef2f2; border:1px solid #fecaca; border-radius:6px; color:#991b1b; font-size:14px;">
        @TempData["Error"]
    </div>
}

<div class="card" style="max-width: 600px;">
    <div class="form-section-title">Owner Summary</div>

    <div class="form-row">
        <div class="form-group">
            <div class="form-label">Name</div>
            <div style="font-weight: 600;">@Model.FirstName @Model.LastName</div>
        </div>
        <div class="form-group">
            <div class="form-label">Email</div>
            <div>@(Model.EmailAddress ?? "—")</div>
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <div class="form-label">Phone</div>
            <div>@(Model.PhoneNumber ?? "—")</div>
        </div>
        <div class="form-group">
            <div class="form-label">City</div>
            <div>@(Model.Address?.CityName ?? "—")</div>
        </div>
    </div>

    @if (!canDelete)
    {
        <div style="margin-top: 16px; padding: 12px 16px; background-color: #fffbeb; border: 1px solid #fcd34d; border-radius: 6px; color: #92400e; font-size: 14px;">
            <strong>Cannot delete this owner.</strong> The following linked records must be removed first:
            <ul style="margin: 6px 0 0 16px; padding: 0;">
                @if (ownershipCount > 0)
                {
                    <li>@ownershipCount property ownership record(s) — remove via Property Ownership</li>
                }
            </ul>
        </div>
    }
    else
    {
        <div style="margin-top: 20px; padding: 12px 16px; background-color: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; color: #991b1b; font-size: 14px;">
            <strong>Warning:</strong> This action is permanent and cannot be undone.
        </div>
    }

    <form asp-action="Delete" asp-route-id="@Model.OwnerId" method="post" style="margin-top: 20px;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OwnerId" />
        <input type="submit" value="Delete Owner" class="btn btn-danger" @(!canDelete ? "disabled" : "") />
        <a asp-action="Index" class="btn btn-outline" style="margin-left: 8px;">Cancel</a>
    </form>
</div>
