@model IEnumerable<PropertyOwner>

@{
    ViewData["Title"] = "Property Owners";
    var canAdmin = (await Auth.AuthorizeAsync(User, DwsPolicies.CanAdminister)).Succeeded;
}

<div class="flex-between mb-16">
    <div>
        <div class="page-title">Property Owners</div>
        <div class="page-subtitle">@Model.Count() owner(s) registered</div>
    </div>
    <div>
        @if (canAdmin)
        {
            <a asp-controller="Owner" asp-action="Register" class="btn btn-primary">+ Register Owner</a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div style="margin-bottom:14px; padding:10px 14px; background:#ecfdf5; border:1px solid #6ee7b7; border-radius:6px; color:#065f46; font-size:14px;">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="margin-bottom:14px; padding:10px 14px; background:#fef2f2; border:1px solid #fecaca; border-radius:6px; color:#991b1b; font-size:14px;">
        @TempData["Error"]
    </div>
}

<div class="data-table-wrap">
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>City</th>
                <th>HDI</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center; color:#8892a0; padding:24px;">No owners registered yet.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FirstName @item.LastName</td>
                    <td>@(item.EmailAddress ?? "—")</td>
                    <td>@(item.PhoneNumber ?? "—")</td>
                    <td>@(item.Address?.CityName ?? "—")</td>
                    <td>
                        @if (item.IsHDI)
                        {
                            <span class="badge badge-green">HDI</span>
                        }
                        else
                        {
                            <span class="badge badge-grey">No</span>
                        }
                    </td>
                    <td>
                        @if (canAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.OwnerId" class="btn btn-sm btn-outline">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.OwnerId" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="table-pagination">
        <span>Showing @Model.Count() owners</span>
    </div>
</div>
