@model PropertyOwner
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Edit Property Owner";
}

<a asp-controller="Owner" asp-action="Index" class="btn-back">&larr; Back to Property Owners</a>

<div class="page-title">Edit Property Owner</div>
<div class="page-subtitle">Update details for @Model.FirstName @Model.LastName</div>

<div class="card" style="max-width: 800px;">
    <form asp-action="Edit" asp-route-id="@Model.OwnerId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OwnerId" />
        <input type="hidden" asp-for="AddressId" />
        @if (Model.Address != null)
        {
            <input type="hidden" asp-for="Address!.AddressId" />
        }

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>

        <div class="form-section-title">Personal Details</div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" style="width:100%;" />
                <span asp-validation-for="FirstName" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" style="width:100%;" />
                <span asp-validation-for="LastName" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" style="width:100%;" placeholder="Mr, Ms, Dr, etc." />
                <span asp-validation-for="Title" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="Gender" class="form-label"></label>
                <select asp-for="Gender" class="form-control" style="width:100%;">
                    <option value="">-- Select --</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="IdentityDocumentNumber" class="form-label"></label>
                <input asp-for="IdentityDocumentNumber" class="form-control" style="width:100%;" />
                <span asp-validation-for="IdentityDocumentNumber" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="DateOfBirth" class="form-label"></label>
                <input asp-for="DateOfBirth" type="date" class="form-control" style="width:100%;" />
                <span asp-validation-for="DateOfBirth" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="EmailAddress" class="form-label"></label>
                <input asp-for="EmailAddress" type="email" class="form-control" style="width:100%;" />
                <span asp-validation-for="EmailAddress" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" style="width:100%;" />
                <span asp-validation-for="PhoneNumber" class="text-danger text-sm"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="CustomerTypeId" class="form-label">Customer Type</label>
                <select asp-for="CustomerTypeId" class="form-control" style="width:100%;"
                        asp-items="@(new SelectList((IEnumerable<CustomerType>)(ViewBag.CustomerTypes ?? new List<CustomerType>()), "Id", "CustomerTypeName"))">
                    <option value="">-- Select Customer Type --</option>
                </select>
                <span asp-validation-for="CustomerTypeId" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label class="form-label" style="display:block;">&nbsp;</label>
                <div style="display:flex; align-items:center; gap:8px; margin-top:4px;">
                    <input asp-for="IsHDI" type="checkbox" style="width:16px; height:16px;" />
                    <label asp-for="IsHDI" class="form-label" style="margin:0;">Historically Disadvantaged Individual (HDI)</label>
                </div>
            </div>
        </div>

        @if (Model.Address != null)
        {
            <div class="form-section-title" style="margin-top: 20px;">Address</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Address!.StreetAddress" class="form-label">Street Address</label>
                    <input asp-for="Address!.StreetAddress" class="form-control" style="width:100%;" />
                    <span asp-validation-for="Address!.StreetAddress" class="text-danger text-sm"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Address!.SuburbName" class="form-label">Suburb</label>
                    <input asp-for="Address!.SuburbName" class="form-control" style="width:100%;" />
                    <span asp-validation-for="Address!.SuburbName" class="text-danger text-sm"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Address!.CityName" class="form-label">City</label>
                    <input asp-for="Address!.CityName" class="form-control" style="width:100%;" />
                    <span asp-validation-for="Address!.CityName" class="text-danger text-sm"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Address!.Province" class="form-label">Province</label>
                    <input asp-for="Address!.Province" class="form-control" style="width:100%;" />
                    <span asp-validation-for="Address!.Province" class="text-danger text-sm"></span>
                </div>
            </div>
        }

        <div style="margin-top: 20px;">
            <input type="submit" value="Save Changes" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-outline" style="margin-left: 8px;">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
