@model ICollection<DamCalculationViewModel>

@{
    ViewData["Title"] = "Dam Calculations";
    var propertyId = ViewBag.PropertyId as Guid? ?? Guid.Empty;
    var propertyRef = ViewBag.PropertyRef as string ?? "Property";
    var canCapture = (await Auth.AuthorizeAsync(User, DwsPolicies.CanCapture)).Succeeded;
}

<a asp-controller="FileMaster" asp-action="Index" class="btn-back">&larr; Back to V&amp;V Cases</a>

<div class="page-title">Dam Calculations</div>
<div class="page-subtitle">Property: @propertyRef</div>

@if (canCapture)
{
    <div style="margin-bottom: 16px;">
        <a asp-action="Create" asp-route-propertyId="@propertyId" class="btn btn-primary">+ Add Dam Calculation</a>
    </div>
}

<div class="card" style="max-width: 1000px;">
    @if (!Model.Any())
    {
        <p style="color: var(--dws-text-muted); padding: 12px 0;">No dam calculations captured yet.</p>
    }
    else
    {
        <div class="data-table-wrap">
            <table class="dws-table">
                <thead>
                    <tr>
                        <th>Dam No.</th>
                        <th>River</th>
                        <th>Calculation Date</th>
                        <th>Survey Date</th>
                        <th>Capacity (m³)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td>@(row.DamNumber ?? "--")</td>
                            <td>@(row.RiverName ?? "--")</td>
                            <td>@row.CalculationDate.ToString("dd MMM yyyy")</td>
                            <td>@row.SateliteSurveyDate.ToString("dd MMM yyyy")</td>
                            <td>@row.DamCapacity.ToString("N2")</td>
                            <td>@row.DamCalculationStatus.ToString().Replace("_", " ")</td>
                            <td>
                                @if (canCapture)
                                {
                                    <a asp-action="Edit" asp-route-id="@row.DamCalculationId" class="btn btn-sm btn-primary">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@row.DamCalculationId" method="post" style="display:inline;"
                                          onsubmit="return confirm('Delete this dam calculation?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
