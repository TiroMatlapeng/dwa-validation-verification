@model dwa_ver_val.ViewModels.Admin.ReferenceDataIndexViewModel
@{
    ViewData["Title"] = "Reference Data";
}

<div class="dws-page-header">
    <h1>Reference Data</h1>
</div>
<p class="page-subtitle">Lookup tables used by the V&amp;V capture forms. Deletes are blocked while a value is still in use.</p>

<!-- Rivers -->
<section class="card" style="margin-bottom:24px;">
    <div class="dws-page-header">
        <h2>Rivers</h2>
        <a asp-action="CreateRiver" class="dws-btn dws-btn-primary">Add River</a>
    </div>
    <table class="dws-table">
        <thead><tr><th>Name</th><th></th></tr></thead>
        <tbody>
        @foreach (var r in Model.Rivers)
        {
            <tr>
                <td>@r.RiverName</td>
                <td>
                    <div class="dws-row-actions">
                        <a asp-action="EditRiver" asp-route-id="@r.RiverId" class="dws-btn dws-btn-ghost">Edit</a>
                        <form asp-action="DeleteRiver" asp-route-id="@r.RiverId" method="post" class="dws-inline-form" onsubmit="return confirm('Delete this river?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dws-btn dws-btn-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        @if (Model.Rivers.Count == 0) { <tr><td colspan="2">None.</td></tr> }
        </tbody>
    </table>
</section>

<!-- Catchment Areas -->
<section class="card" style="margin-bottom:24px;">
    <div class="dws-page-header">
        <h2>Catchment Areas</h2>
        <a asp-action="CreateCatchment" class="dws-btn dws-btn-primary">Add Catchment</a>
    </div>
    <table class="dws-table">
        <thead><tr><th>Code</th><th>Name</th><th>WMA</th><th></th></tr></thead>
