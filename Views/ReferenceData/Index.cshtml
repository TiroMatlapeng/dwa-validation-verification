        @foreach (var c in Model.CatchmentAreas)
        {
            <tr>
                <td>@c.CatchmentCode</td>
                <td>@c.CatchmentName</td>
                <td>@(c.WaterManagementArea?.WmaName ?? "—")</td>
                <td>
                    <div class="dws-row-actions">
                        <a asp-action="EditCatchment" asp-route-id="@c.CatchmentAreaId" class="dws-btn dws-btn-ghost">Edit</a>
                        <form asp-action="DeleteCatchment" asp-route-id="@c.CatchmentAreaId" method="post" class="dws-inline-form" onsubmit="return confirm('Delete this catchment?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dws-btn dws-btn-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        @if (Model.CatchmentAreas.Count == 0) { <tr><td colspan="4">None.</td></tr> }
        </tbody>
    </table>
</section>

