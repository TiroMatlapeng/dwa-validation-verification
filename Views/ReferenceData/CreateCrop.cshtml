@model dwa_ver_val.ViewModels.Admin.CropFormViewModel
@{ ViewData["Title"] = "Add Crop"; }
<div class="dws-page-header"><h1>Add Crop</h1></div>
<form asp-action="CreateCrop" method="post" class="dws-form">
    <div asp-validation-summary="All" class="dws-validation-summary"></div>
    <div class="dws-form-row">
        <label asp-for="CropName" class="dws-label"></label>
        <input asp-for="CropName" class="dws-input" />
        <span asp-validation-for="CropName" class="dws-field-error"></span>
    </div>
    <div class="dws-form-row">
        <label asp-for="CropTypeId" class="dws-label"></label>
        <select asp-for="CropTypeId" class="dws-input">
            <option value="">-- No Type --</option>
            @foreach (var t in Model.AvailableCropTypes)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
        <span asp-validation-for="CropTypeId" class="dws-field-error"></span>
    </div>
    <button type="submit" class="dws-btn dws-btn-primary">Create</button>
    <a asp-action="Index" class="dws-btn dws-btn-ghost">Cancel</a>
</form>
