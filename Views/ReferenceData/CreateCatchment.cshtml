@model dwa_ver_val.ViewModels.Admin.CatchmentAreaFormViewModel
@{ ViewData["Title"] = "Add Catchment Area"; }
<div class="dws-page-header"><h1>Add Catchment Area</h1></div>
<form asp-action="CreateCatchment" method="post" class="dws-form">
    <div asp-validation-summary="All" class="dws-validation-summary"></div>
    <div class="dws-form-row">
        <label asp-for="CatchmentCode" class="dws-label"></label>
        <input asp-for="CatchmentCode" class="dws-input" placeholder="e.g. A21A" />
        <span asp-validation-for="CatchmentCode" class="dws-field-error"></span>
    </div>
    <div class="dws-form-row">
        <label asp-for="CatchmentName" class="dws-label"></label>
        <input asp-for="CatchmentName" class="dws-input" />
        <span asp-validation-for="CatchmentName" class="dws-field-error"></span>
    </div>
    <div class="dws-form-row">
        <label asp-for="WmaId" class="dws-label"></label>
        <select asp-for="WmaId" class="dws-input">
            <option value="">-- Select WMA --</option>
            @foreach (var wma in Model.AvailableWmas)
            {
                <option value="@wma.Id">@wma.Name</option>
            }
        </select>
        <span asp-validation-for="WmaId" class="dws-field-error"></span>
    </div>
    <button type="submit" class="dws-btn dws-btn-primary">Create</button>
    <a asp-action="Index" class="dws-btn dws-btn-ghost">Cancel</a>
</form>
