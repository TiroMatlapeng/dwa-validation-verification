@model IEnumerable<OngoingValidationRow>
@{
    ViewData["Title"] = "Ongoing Validations";
}

<div class="dws-page-header">
    <h1>Ongoing Validations</h1>
    <a asp-controller="FileMaster" asp-action="Create" class="dws-btn dws-btn-primary">Start a New Case</a>
</div>

@if (!Model.Any())
{
    <div class="dws-panel">
        <p style="color: var(--dws-text-muted); margin: 0;">
            No cases are currently in validation. Create a new V&amp;V case from
            <a asp-controller="FileMaster" asp-action="Index">V&amp;V Cases</a> to begin.
        </p>
    </div>
}
else
{
    <table class="dws-table">
        <thead>
            <tr>
                <th>V&amp;V Case</th>
                <th>Property</th>
                <th>Farm</th>
                <th>Track</th>
                <th>Phase</th>
                <th>Current State</th>
                <th>Opened</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model)
        {
            var pillClass = row.ValidationStatus switch
            {
                "Completed" or "Compl Not Client Interaction" or "Compl Post Interact Processing"
                                         => "dws-status-pill dws-status-pill--ok",
                "In Process"             => "dws-status-pill dws-status-pill--warning",
                _                        => "dws-status-pill"
            };
            <tr>
                <td><strong>@row.CaseNumber</strong></td>
                <td>@row.PropertyReference</td>
                <td>@row.FarmName</td>
                <td>
                    @{
                        var trackLabel = row.AssessmentTrack switch
                        {
                            "S35_Verification"   => "S35 Verification",
                            "S33_2_Declaration"  => "S33(2) Declaration",
                            "S33_3_Declaration"  => "S33(3) Declaration",
                            _                    => row.AssessmentTrack
                        };
                    }
                    @trackLabel
                </td>
                <td>@row.CurrentPhase</td>
                <td><code>@row.CurrentStateName</code></td>
                <td>@row.FileCreatedDate.ToString("dd MMM yyyy")</td>
                <td><span class="@pillClass">@row.ValidationStatus</span></td>
                <td>
                    <a asp-controller="FileMaster" asp-action="Details" asp-route-id="@row.FileMasterId" class="dws-btn dws-btn-ghost">Open</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
