@model IEnumerable<Property>

@{
    ViewData["Title"] = "Properties";
}

<div class="flex-between mb-16">
    <div>
        <div class="page-title">Properties</div>
        <div class="page-subtitle">@Model.Count() properties found</div>
    </div>
    <div style="display:flex; gap:8px;">
        <button class="btn btn-outline">Export CSV</button>
        <a asp-controller="Property" asp-action="Register" class="btn btn-primary">+ New Property</a>
    </div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <select class="form-select" style="width:auto; min-width:150px; padding:6px 10px; font-size:12px; border:1px solid #d0d5db; border-radius:4px;">
        <option>All WMAs</option>
    </select>
    <select class="form-select" style="width:auto; min-width:150px; padding:6px 10px; font-size:12px; border:1px solid #d0d5db; border-radius:4px;">
        <option>All Statuses</option>
        <option>Not Commenced</option>
        <option>In Process</option>
        <option>Completed</option>
    </select>
    <select class="form-select" style="width:auto; min-width:150px; padding:6px 10px; font-size:12px; border:1px solid #d0d5db; border-radius:4px;">
        <option>All Water Use</option>
        <option>Irrigation</option>
        <option>Storage</option>
        <option>Forestation</option>
    </select>
    <input type="text" class="form-input" style="width:200px; padding:6px 10px; font-size:12px; border:1px solid #d0d5db; border-radius:4px;" placeholder="SG Code or Farm Name..." />
    <button class="btn btn-primary btn-sm">Filter</button>
    <button class="btn btn-outline btn-sm">Clear</button>
</div>

<!-- Data Table -->
<div class="data-table-wrap">
    <table>
        <thead>
            <tr>
                <th>SG Code</th>
                <th>Farm Name</th>
                <th>WMA</th>
                <th>Quaternary Drainage</th>
                <th>Property Size</th>
                <th>V&amp;V Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="sg-code">@item.SGCode</td>
                    <td>@item.PropertyReferenceNumber</td>
                    <td>@item.WaterManagementArea?.WmaName</td>
                    <td>@item.QuaternaryDrainage</td>
                    <td>@item.PropertySize</td>
                    <td><span class="badge badge-grey">Not Commenced</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.PropertyId" class="btn btn-sm btn-outline">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.PropertyId" class="btn btn-sm btn-outline">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.PropertyId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="table-pagination">
        <span>Showing @Model.Count() properties</span>
    </div>
</div>
