@model dwa_ver_val.ViewModels.SubdivideViewModel

@{
    ViewData["Title"] = "Subdivide Property";
    var parent = Model.ParentProperty!;
    var headingLabel = !string.IsNullOrWhiteSpace(parent.SGCode)
        ? parent.SGCode
        : parent.PropertyReferenceNumber ?? parent.PropertyId.ToString();
}

<a asp-controller="Property" asp-action="Details" asp-route-id="@parent.PropertyId" class="btn-back">&larr; Back to Property</a>

<div class="page-title">Subdivide property: @headingLabel</div>
<div class="page-subtitle">
    The original property will be preserved with status <strong>Subdivided</strong>.
    Each row below becomes a new <strong>Active</strong> property inheriting the parent's
    Water Management Area, Catchment, Quaternary Drainage and Address.
</div>

@if (TempData["Error"] is string err)
{
    <div class="badge badge-red" style="display:block;padding:10px 14px;margin-bottom:14px;">@err</div>
}

<div class="card" style="margin-bottom: 16px;">
    <div class="form-section-title">Parent Property</div>
    <div class="form-row">
        <div class="form-group">
            <div class="form-label">SG Code</div>
            <div>@(parent.SGCode ?? "—")</div>
        </div>
        <div class="form-group">
            <div class="form-label">Water Management Area</div>
            <div>@(parent.WaterManagementArea?.WmaName ?? "—")</div>
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            <div class="form-label">Property Reference Number</div>
            <div>@(parent.PropertyReferenceNumber ?? "—")</div>
        </div>
        <div class="form-group">
            <div class="form-label">Property Size (ha)</div>
            <div>@parent.PropertySize.ToString("N2")</div>
        </div>
    </div>
</div>

<div class="card" style="max-width: 900px;">
    <form asp-action="Subdivide" asp-route-id="@parent.PropertyId" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom:14px;"></div>

        <div class="form-section-title">New Child Properties</div>
        <p style="font-size:13px;color:#6b7280;margin-bottom:12px;">
            Provide at least 2 children. Leave a row's SG Code blank to skip it.
        </p>

        @for (var i = 0; i < Model.Children.Count; i++)
        {
            <div class="card" style="background:#f8fafc;margin-bottom:12px;padding:14px;">
                <div class="form-section-title" style="font-size:13px;margin-bottom:8px;">Child @(i + 1)</div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Children[i].SGCode" class="form-label"></label>
                        <input asp-for="Children[i].SGCode" class="form-control" style="width:100%;" />
                        <span asp-validation-for="Children[i].SGCode" class="text-danger text-sm"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Children[i].PropertyReferenceNumber" class="form-label"></label>
                        <input asp-for="Children[i].PropertyReferenceNumber" class="form-control" style="width:100%;" />
                        <span asp-validation-for="Children[i].PropertyReferenceNumber" class="text-danger text-sm"></span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Children[i].PropertySize" class="form-label"></label>
                        <input asp-for="Children[i].PropertySize" type="number" step="0.01" min="0" class="form-control" style="width:100%;" />
                        <span asp-validation-for="Children[i].PropertySize" class="text-danger text-sm"></span>
                    </div>
                    <div class="form-group">
                        <!-- spacer -->
                    </div>
                </div>
            </div>
        }

        <div style="margin-top:16px;">
            <input type="submit" value="Subdivide property" class="btn btn-primary" />
            <a asp-action="Details" asp-route-id="@parent.PropertyId" class="btn btn-outline" style="margin-left:8px;">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
