@{
    ViewData["Title"] = "Password updated";
    Layout = "_LoginLayout";
}

<div class="dws-card dws-card--login">
    <h1>Password updated</h1>
    <p style="color: var(--dws-text-muted); font-size: var(--dws-fs-sm);">
        Your password has been set. You can now sign in with your new credentials.
    </p>
    <a asp-action="Login" class="dws-btn dws-btn-primary">Sign in</a>
</div>
