@model dwa_ver_val.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Set a new password";
    Layout = "_LoginLayout";
}

<div class="dws-card dws-card--login">
    <h1>Set a new password</h1>
    <p style="color: var(--dws-text-muted); font-size: var(--dws-fs-sm); margin-top: 0;">
        Setting password for <strong>@Model.Email</strong>.
    </p>

    <form asp-action="ResetPassword" method="post" class="dws-form">
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />
        <div asp-validation-summary="All" class="dws-validation-summary"></div>

        <div class="dws-form-row">
            <label asp-for="NewPassword" class="dws-label"></label>
            <input asp-for="NewPassword" class="dws-input" type="password" autocomplete="new-password" autofocus />
            <span asp-validation-for="NewPassword" class="dws-field-error"></span>
        </div>

        <div class="dws-form-row">
            <label asp-for="ConfirmPassword" class="dws-label"></label>
            <input asp-for="ConfirmPassword" class="dws-input" type="password" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="dws-field-error"></span>
        </div>

        <button type="submit" class="dws-btn dws-btn-primary">Set password</button>
    </form>
</div>
