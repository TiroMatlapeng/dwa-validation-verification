@model dwa_ver_val.ViewModels.ForgotPasswordResultViewModel
@{
    ViewData["Title"] = "Reset link";
    Layout = "_LoginLayout";
}

<div class="dws-card dws-card--login">
    <h1>Check your email</h1>
    <p style="color: var(--dws-text-muted); font-size: var(--dws-fs-sm);">
        If an account exists for <strong>@Model.Email</strong>, a password-reset link has been issued.
    </p>

    @if (!string.IsNullOrEmpty(Model.ResetLink))
    {
        <div class="dws-validation-summary" style="background: var(--dws-warning-bg); border-color: var(--dws-warning); color: var(--dws-warning);">
            <strong>Demo mode — email service is not yet configured.</strong><br />
            Use the link below to set a new password:
            <div style="margin-top: var(--dws-space-2); word-break: break-all;">
                <a href="@Model.ResetLink" style="color: var(--dws-warning); text-decoration: underline;">@Model.ResetLink</a>
            </div>
        </div>
    }

    <div style="margin-top: var(--dws-space-4); text-align: center;">
        <a asp-action="Login" class="dws-btn dws-btn-ghost">Back to sign in</a>
    </div>
</div>
