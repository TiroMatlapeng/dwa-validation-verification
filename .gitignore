# Build output
bin/
obj/
publish/
publish-azure/
publish-azure.zip
app.zip

# Office temp / lock files (e.g. ~$Document.docx that Office writes while open)
~$*
**/~$*

# Claude Code local state (agents, settings.local.json) — personal, not project
.claude/

# Wireframe screenshots — 8MB+ of PNGs that take-screenshots.js regenerates
docs/wireframes/screenshots-v2/

# Visual Studio / Rider
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.idea/

# macOS
.DS_Store
**/.DS_Store

# NuGet
*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core — libman-restored packages are not committed
wwwroot/lib/*
!wwwroot/lib/d3/

# Logs
*.log
logs/

# Environment / secrets
appsettings.Local.json
appsettings.Production.json
secrets.json

# Git worktrees
.worktrees/

# Generated runtime uploads (letter PDFs, etc.)
# wwwroot/_uploads/ entry retained for safety in case a stray file appears there.
wwwroot/_uploads/
# SEC/DOC-01: letter blobs live here (outside wwwroot) — PII, never commit.
letter-blobs/
# Portal uploads — PII, never commit.
portal-uploads/

# Test runner output
Tests/TestResults/

# PRD reference documents (source of truth kept outside repo)
PRD Documentation/
