    ExtSys <--> IntegSvc["Integration Service Layer\n(IIntegrationService)"]

    IntegSvc --> P1 & P2 & P3

    subgraph P1["Phase 1: Project Inception (CP01–CP05)"]
        P1A["WARMS Audit → New FileMaster records\nUnregistered User GIS Identification\nDatabase Status Analysis\nInception Report + Public Participation 1"]
    end

    subgraph P2["Phase 2: Validation — Technical Extent per Property (CP06–CP16)"]
        P2A["WARMS Evaluation → Irrigation / Storing / Forestation\nSpatial Info → Mapbook / Property / CatchmentArea\nSupportive Info → FileMaster\nProperty & Source Eval → Property / PropertyOwner / WaterSource\nAdditional Info → Authorisation / Entitlement\nGIS Analysis → FieldAndCrop / DamCalculation\nSAPWAT → FieldAndCrop.SAPWATCalculationResult\nELU → Irrigation (9 scenarios) / Entitlement\nDam Volumes → DamCalculation / Storing\nSFRA → Forestation"]
    end

    subgraph P3["Phase 3: Verification — Legal Lawfulness / Section 35 + Section 33 (CP17–CP21)"]
        P3A["Public Participation Session 2\nField Visit Letter Dissemination\nSection 35 Correspondence Tracking\nS33(2) Kader Asmal Declaration Track\nS33(3) Individual Application Track\nLetter State Machine (L1→L3/Enforcement)\nProject Control Reporting"]
    end

    P1 & P2 & P3 --> WFEngine

    subgraph EngineLayer["Engine Layer"]
        WFEngine["Workflow Engine\n(IWorkflowEngine)\nState machine — CP transitions\nGuards, role checks\nEvery transition audited"]
        CalcEng["Calculator Engine\n(ICalculatorEngine)\nSAPWAT · Dam Volumes · ELU · SFRA"]
        LetterSvc["Letter Service\n(ILetterService)\nGenerate · Sign · Issue · Batch · Track"]
        NotifSvc["Notification Engine\n(INotificationService)\nIn-App · Email · Background reminders"]
        SigSvc["Signature Service\n(ISignatureService)\nSignaturePad.js capture · SHA-256 verify"]
        AuditSvc["Audit Service\n(IAuditService)\nImmutable AuditLog — who, what, when"]
    end

    WFEngine --> CalcEng & LetterSvc & NotifSvc & SigSvc & AuditSvc

    EngineLayer --> SvcLayer

    subgraph SvcLayer["Service Layer"]
        Svcs["PropertyService · ValidationService · FileMasterService\nForestationService · IrrigationService · StoringService\nReportingService · PublicCaseService · IntegrationService"]
    end

    SvcLayer --> RepoLayer

    subgraph RepoLayer["Repository Layer (EF Core)"]
        Repos["PropertyRepo · FileMasterRepo · WorkflowRepo\nLetterIssuanceRepo · AddressRepo · ForestationRepo\nFieldAndCropRepo · DamCalculationRepo · ValidationRepo · …"]
    end

