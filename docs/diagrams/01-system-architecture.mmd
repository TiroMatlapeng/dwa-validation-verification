graph TB
    subgraph External["External Systems"]
        WARMS["WARMS\n(Water Use Registration)"]
        eWULAAS["eWULAAS\n(Licence Applications)"]
        SG["Surveyor General\n(DRDLR)"]
        Deeds["Deeds Office\n(DRDLR)"]
        GIS["Satellite / GIS\nImage Store\n& Mapbooks"]
    end

    subgraph Clients["User Interfaces"]
        InternalApp["Internal MVC App\n(DWS/CMA Officials)\n/Admin, /Property, /Validation\n/Workflow, /Reports, /Letters"]
        PublicPortal["Public Portal\n(Water Users)\n/Portal/Login, /Portal/Dashboard\n/Portal/Cases, /Portal/Protests\n/Portal/Documents"]
    end

    subgraph Services["Service Layer"]
        WE["Workflow Engine\n(WorkflowState DB table\n+ ITransitionGuard)"]
        CE["Calculator Engine\n(SAPWAT, Dam, ELU, SFRA)"]
        LS["Letter Service\n(Generate, Track, Batch)"]
        NS["Notification Service\n(Email + In-App)"]
        SS["Signature Service\n(Capture + Verify)"]
        IS["Integration Service\n(WARMS, eWULAAS, SG, Deeds)"]
        AS["Audit Service\n(Immutable AuditLog)"]
        RS["Reporting Service"]
    end

    subgraph Repositories["Repository Layer"]
        PR["PropertyRepo"]
        FR["FileMasterRepo"]
        WR["WorkflowRepo"]
        LR["LetterRepo"]
        OR["Other Repos..."]
    end

    subgraph Database["SQL Server Database"]
        CoreDB["Core Domain\nProperties, Owners\nFileMasters\nIrrigation, Storing\nForestation, FieldAndCrop\nDamCalculation"]
        RefDB["Reference Tables\nValidationStatus, WaterSourceType\nVerificationScenario, CustomerTitle\nGender, DamCalculationStatus\nEntitlementType, AuthorisationType\nLetterType, Period"]
        OrgDB["Organisation\nProvinces\nWaterManagementAreas\nCatchmentAreas\nOrganisationalUnits"]
        WorkflowDB["Workflow\nWorkflowStates\nWorkflowInstances\nWorkflowStepRecords\nAuditLog"]
        CorrespDB["Correspondence\nLetterIssuances\nAuthorisations\nUploadedDocuments\nDigitalSignatures"]
        PortalDB["Public Portal\nPublicUsers\nPublicUserProperties\nCaseNotifications\nCaseComments\nObjections [AMENDED]\nObjectionDocuments [AMENDED]"]
    end

    InternalApp --> Services
    PublicPortal --> Services
    Services --> Repositories
    Repositories --> Database

    IS <--> WARMS
    IS <--> eWULAAS
    IS <--> SG
    IS <--> Deeds
    IS <--> GIS

